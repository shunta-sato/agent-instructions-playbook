{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Embedded operating envelope report",
  "type": "object",
  "required": ["target", "scenario", "status", "safety_limits", "findings"],
  "properties": {
    "target": { "type": "string" },
    "feature": { "type": "string" },
    "scenario": {
      "enum": [
        "idle",
        "nominal",
        "peak",
        "near_boundary",
        "degraded",
        "observer_off",
        "observer_on",
        "recovery",
        "blackout_or_telemetry_loss"
      ]
    },
    "status": {
      "enum": ["pass", "fail", "unknown", "not_run", "unsafe_to_run"]
    },
    "duration_seconds": { "type": ["number", "null"] },
    "safety_limits": {
      "type": "array",
      "items": { "type": "string" }
    },
    "measurements": {
      "type": "object",
      "additionalProperties": true
    },
    "findings": {
      "type": "object",
      "required": ["boundary_findings", "telemetry_blackout"],
      "properties": {
        "normal_range": { "type": "string" },
        "near_boundary_indicators": { "type": "array", "items": { "type": "string" } },
        "degradation_signals": { "type": "array", "items": { "type": "string" } },
        "boundary_findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["signal", "boundary_type", "threshold", "unit", "confidence", "evidence"],
            "properties": {
              "signal": { "type": "string" },
              "boundary_type": {
                "enum": ["normal", "near_boundary", "degraded", "failure_adjacent", "recovery", "blackout_or_telemetry_loss"]
              },
              "threshold": { "type": ["number", "string", "null"] },
              "unit": { "type": "string" },
              "confidence": { "enum": ["high", "medium", "low", "unknown"] },
              "evidence": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "telemetry_blackout": {
          "type": "object",
          "required": ["observed", "signal_id", "expected_cadence_ms", "confidence"],
          "properties": {
            "observed": { "type": "boolean" },
            "signal_id": { "type": "string" },
            "last_seen_time": { "type": ["string", "null"] },
            "expected_cadence_ms": { "type": ["number", "null"] },
            "confidence": { "enum": ["high", "medium", "low", "unknown"] }
          },
          "additionalProperties": true
        },
        "observer_effect": { "type": "string" },
        "no_go_boundary": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
