{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Embedded operating envelope report",
  "type": "object",
  "required": ["target", "scenario", "status", "safety_limits", "findings"],
  "properties": {
    "target": { "type": "string" },
    "feature": { "type": "string" },
    "scenario": {
      "enum": [
        "idle",
        "nominal",
        "peak",
        "near_boundary",
        "degraded",
        "observer_off",
        "observer_on",
        "recovery",
        "blackout_or_telemetry_loss"
      ]
    },
    "status": {
      "enum": ["pass", "fail", "unknown", "not_run", "unsafe_to_run"]
    },
    "duration_seconds": { "type": ["number", "null"] },
    "safety_limits": {
      "type": "array",
      "items": { "type": "string" }
    },
    "measurements": {
      "type": "object",
      "additionalProperties": true
    },
    "findings": {
      "type": "object",
      "properties": {
        "normal_range": { "type": "string" },
        "near_boundary_indicators": { "type": "array", "items": { "type": "string" } },
        "degradation_signals": { "type": "array", "items": { "type": "string" } },
        "telemetry_blackout": { "type": "string" },
        "observer_effect": { "type": "string" },
        "no_go_boundary": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
